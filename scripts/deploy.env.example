# deploy.env.example — copy to ./deploy.env (repo root) and fill in.
#
#   cp scripts/deploy.env.example deploy.env
#   scripts/deploy.sh            # plan-only (default)
#   scripts/deploy.sh --apply    # explicit apply (your manual step)
#
# deploy.env is GITIGNORED. It holds only non-secret IDs + backend config. Application
# secrets (Slack tokens, PROXY_API_KEY, Kiro SSO) live in AWS Secrets Manager and are
# injected at runtime — NEVER put secrets in this file.

# --- Required: existing network (consumed via data sources, never managed) ---
AWS_REGION="us-east-1"
NAME_PREFIX="slack-devops-agent"
EXISTING_VPC_ID="vpc-0abc1234567890def"

# List values MUST be HCL/JSON list strings (quotes + brackets), passed through to TF_VAR_*.
EXISTING_PRIVATE_SUBNET_IDS='["subnet-0aaa111","subnet-0bbb222"]'
EXISTING_SECURITY_GROUP_IDS='["sg-0abc1234567890def"]'

# --- Required: remote-state backend (S3 + DynamoDB lock) ---
TF_BACKEND_BUCKET="my-terraform-state-bucket"
TF_BACKEND_KEY="slack-devops-agent/unit-001/terraform.tfstate"
TF_BACKEND_REGION="us-east-1"
TF_BACKEND_DYNAMODB_TABLE="terraform-state-lock"

# --- Optional: mode + environment ---
# Defaults to true in deploy.sh (this script's purpose is existing-VPC deploys).
USE_EXISTING_NETWORK="true"
ENVIRONMENT="dev"
EXISTING_NAT_GATEWAY="false"            # true to reuse the existing VPC's NAT (skip creating one)

# --- Optional: existing ALB (add a listener rule instead of creating an ALB) ---
EXISTING_ALB="false"
EXISTING_ALB_LISTENER_ARN=""            # arn:aws:elasticloadbalancing:...:listener/app/my-alb/.../...

# --- Optional: per-endpoint interface VPC endpoint toggles ---
# DynamoDB/S3 are free gateway endpoints (always created, not toggled).
CREATE_SQS_ENDPOINT="true"
CREATE_SECRETSMANAGER_ENDPOINT="true"
CREATE_LOGS_ENDPOINT="true"
CREATE_ECR_API_ENDPOINT="true"
CREATE_ECR_DKR_ENDPOINT="true"
CREATE_BEDROCK_ENDPOINT="false"         # default off — Bedrock failover egresses via NAT

# --- Optional: inference / grounding (omit to use the terraform defaults) ---
# These map to worker env vars. Leave unset to take the repo defaults
# (KIRO_MODEL=claude-sonnet-4.6, KIRO_TIMEOUT_SECONDS=70, the public MCP endpoint).
# Set MCP_BASE_URL="" only if you deliberately want to DISABLE MCP grounding.
MCP_BASE_URL="https://knowledge-mcp.global.api.aws"
KIRO_MODEL="claude-sonnet-4.6"
KIRO_TIMEOUT_SECONDS="70"

# --- Optional: gateway sizing + transport (omit to use terraform defaults) ---
# TLS off (default) = plaintext 80/HTTP on the internal private-subnet worker->ALB hop, no ACM
# cert needed. Set true (and GATEWAY_CERTIFICATE_ARN) to restore 443/TLS (NFR-5).
GATEWAY_TLS_ENABLED="false"
# Single gateway task (no Multi-AZ HA). Set both to 2 to restore the F4 baseline.
GATEWAY_DESIRED_COUNT="1"
GATEWAY_AUTOSCALE_MIN_CAPACITY="1"

# --- Optional: artifacts ---
GATEWAY_IMAGE=""                        # e.g. 123456789012.dkr.ecr.us-east-1.amazonaws.com/kiro-gateway:1.0.0
GATEWAY_CERTIFICATE_ARN=""              # ACM cert for a created ALB (only needed with GATEWAY_TLS_ENABLED=true)
LAMBDA_ARTIFACT_S3_BUCKET=""
LAMBDA_ARTIFACT_S3_KEY="slack-devops-agent/unit-001.zip"
