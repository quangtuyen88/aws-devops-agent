# Slack DevOps Agent — example configuration.
# Copy to a real secret store / runtime env; NEVER commit a populated .env.
# Secrets (tokens, API keys) must come from AWS Secrets Manager at runtime (NFR-5).

# --- Slack (CMP-001) ---
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
SLACK_BOT_USER_ID=U000BOT

# --- Inference backend (CMP-003) ---
# backend-id: "kiro" (primary, HTTP-client-only) or "bedrock" (alternate)
INFERENCE_BACKEND=kiro
# Kiro-gateway (external, unmodified AGPL container — operated separately, never vendored)
KIRO_GATEWAY_BASE_URL=http://kiro-gateway.internal
PROXY_API_KEY=REPLACE_ME
KIRO_MODEL=claude-3-5-sonnet
# Bedrock alternate
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- AWS Knowledge MCP (CMP-004) ---
MCP_BASE_URL=https://knowledge-mcp.example.internal
MCP_API_KEY=REPLACE_ME

# --- AWS resources (CMP-006/007/008) ---
AWS_REGION=us-east-1
PROCESSING_JOB_TABLE=slack-devops-agent-processing-job
OPERATIONAL_DATA_TABLE=slack-devops-agent-operational-data
CONFIG_TABLE=slack-devops-agent-config
ANSWER_TS_GSI=answer-ts-index
WORK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/slack-devops-agent-work
DLQ_URL=https://sqs.us-east-1.amazonaws.com/000000000000/slack-devops-agent-dlq

# --- Timing invariant (move in lock-step if tuned) ---
REQUEST_TIME_BUDGET_SECONDS=30
LEASE_STALENESS_SECONDS=90
MAX_ATTEMPTS=3

# --- Cost guardrail / input bounds (operator-set defaults; tunable) ---
MAX_INFERENCE_CALLS=2
MAX_MCP_CALLS=5
PER_PERIOD_LIMIT=500
PERIOD_DEFINITION=day
MAX_INPUT_TOKENS=12000
RESERVED_OUTPUT_TOKENS=4000
